{
	"compilerOptions": {
		"target": "es2016",
		"module": "commonjs",
		"rootDir": "./src",
		"outDir": "./dist",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"types": ["node"]
	},
	"include": ["./src/**/*.ts"],
	"exclude": [
		"node_modules",
		"src/**/*.test.ts",
		"src/**/*.spec.ts",
		"src/**/__test__",
		"src/**/test",
		"src/**/__mocks__"
	]
}
